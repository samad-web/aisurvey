# Server -----------------------------------------------------------------
PORT=4000
NODE_ENV=development

# Database ---------------------------------------------------------------
# Required. Example:
#   postgres://survey:survey@localhost:5432/lexdraft_survey
DATABASE_URL=
# Set to "true" when DATABASE_URL points at a managed Postgres that
# requires SSL (RDS, Neon, Supabase, etc.).
DATABASE_SSL=false

# CORS -------------------------------------------------------------------
# Comma-separated origin allowlist. Empty value = allow all origins (fine
# for local dev). In production set to https://your-survey-domain.example.
CORS_ORIGIN=

# Rate limits (per IP, per hour) -----------------------------------------
SURVEY_LIMIT_PER_HOUR=10
SURVEY_DRAFT_LIMIT_PER_HOUR=120
